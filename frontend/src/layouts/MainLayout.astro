---
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { getLangFromUrl } from '@/i18n/utils';

import DropDownTheme from "@/components/dropdown-theme/DropdownTheme.astro"

const lang = getLangFromUrl(Astro.url);

---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Bar commander</title>
    <script is:inline src="/js/theme.js"></script>
    <ClientRouter />
  </head>
  <body>
    <div class="container mx-auto">
      <DropDownTheme />
      <div class="font-sans text-bar-gray">
        <h1 class="font-heading text-bar-gold text-3xl">Bar Commander</h1>
        <p class="font-sans">Gestiona tu bar con estilo y control.</p>
      </div>
      <slot />
    </div>
    <script src="@/lib/theme"></script>
  </body>
</html>
